---
import Base from '../layouts/Base.astro';
import { WeatherForecast } from '../components/WeatherForecast';
import { readFileSync } from 'node:fs';
import { resolve } from 'node:path';

const base = import.meta.env.BASE_URL;
const manifest = JSON.parse(readFileSync(resolve(process.cwd(), 'public/icons/sprite-manifest.json'), 'utf8'));
const spriteHref = `${base}icons/${manifest.filename}`;
---
<Base title="Valheim Weather Forecast" description="Deterministic weather forecast for all Valheim biomes. Enter your in-game day to plan ahead.">
  <WeatherForecast client:load baseHref={base} spriteHref={spriteHref} />
</Base>
